<Window x:Class="AntiLagPro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AntiLag" Height="760" Width="940"
        Icon="Resources/app.ico"
        WindowStartupLocation="CenterScreen"
        Background="#FF0A0A0E" Foreground="#FFE3E6EB"
        FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Кнопка -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="#FF262630"/>
            <Setter Property="Foreground" Value="#FFE3E6EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                            <Border x:Name="ov" CornerRadius="6">
                                <Border.Background>
                                    <SolidColorBrush Color="#00FFFFFF"/>
                                </Border.Background>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ov"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#1AFFFFFF" Duration="0:0:0.13"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ov"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#00FFFFFF" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Кнопка боковой рельсы -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FF858E9E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" Padding="14,11" Margin="0,2,12,2" CornerRadius="8" Width="180">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16" Width="28" VerticalAlignment="Center"/>
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF15151B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF1F9E58"/>
                                <Setter Property="Foreground" Value="#FFEDEFF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Сегментированный переключатель (пилюли) -->
        <Style x:Key="Seg" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FF858E9E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="#FF1E1E26" CornerRadius="7" Padding="14,7" Margin="0,0,6,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#FF262630"/></Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF1F9E58"/>
                                <Setter Property="Foreground" Value="#FFEDEFF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Тёмный ComboBox под тему -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFE3E6EB"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ci" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ci" Property="Background" Value="#FF1E1E26"/></Trigger>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ci" Property="Background" Value="#FF1F9E58"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFE3E6EB"/>
            <Setter Property="Background" Value="#FF0A0A0E"/>
            <Setter Property="BorderBrush" Value="#FF262630"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="cbd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6"/>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton"><Border Background="Transparent"/></ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="9"
                                       Foreground="#FF858E9E" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#FF15151B" BorderBrush="#FF262630" BorderThickness="1" CornerRadius="6" Margin="0,4,0,4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="280">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="cbd" Property="Background" Value="#FF12121A"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Тонкий скроллбар в тон тёмной теме -->
        <Style x:Key="ThinThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#FF262630" CornerRadius="4" Margin="2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="Orientation" Value="Horizontal"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Переключатель-ползунок вместо квадратной галочки -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE3E6EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="track" Width="42" Height="22" CornerRadius="11">
                                <Border.Background>
                                    <SolidColorBrush Color="#FF262630"/>
                                </Border.Background>
                                <Border x:Name="knob" Width="16" Height="16" CornerRadius="8" Background="#FFE3E6EB"
                                        HorizontalAlignment="Left" Margin="3,0,0,0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="knobT" X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" Margin="9,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="knobT" Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="track"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#FF1F9E58" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="knobT" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="track"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#FF262630" Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="knob" Property="Background" Value="#FFEDEFF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль подсказки (тёмная, скруглённая, с переносом) -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FF15151B"/>
            <Setter Property="Foreground" Value="#FFE3E6EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="11,8"
                                BorderBrush="#FF262630" BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Шаблон находки диагностики -->
        <DataTemplate x:Key="FindingTemplate">
            <Border Background="#FF15151B" CornerRadius="8" Margin="0,0,0,8">
                <Grid>
                    <Border Width="4" HorizontalAlignment="Left" Background="{Binding Accent}" CornerRadius="8,0,0,8"/>
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Detail}" Foreground="#FF858E9E" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding Fix}" Foreground="#FF55B585" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Visibility="{Binding FixVisibility}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Открыть →" Tag="{Binding GoTo}" Click="FindingGoTo_Click"
                                VerticalAlignment="Center" Margin="12,0,0,0" Padding="12,6"
                                Visibility="{Binding GoToVisibility}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Шаблон твика: ползунок + название + статус + «?»-подсказка -->
        <DataTemplate x:Key="TweakTemplate">
            <Border Background="#FF15151B" CornerRadius="10" Padding="14,11" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Border Grid.Column="2" Width="22" Height="22" CornerRadius="11" Background="#FF262630"
                            VerticalAlignment="Center" Cursor="Help"
                            ToolTipService.InitialShowDelay="150" ToolTipService.ShowDuration="60000">
                        <Border.ToolTip>
                            <ToolTip>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="300"/>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock Text="?" Foreground="#FF858E9E" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,12">
            <TextBlock Text="AntiLag" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="v0.4.3" Foreground="#FF565E6E" FontSize="12" VerticalAlignment="Bottom" Margin="6,0,0,5"/>
            <Button x:Name="UpdateButton" Visibility="Collapsed" Background="#FF1F9E58" Padding="10,4"
                    FontSize="12" VerticalAlignment="Bottom" Margin="12,0,0,2" Click="Update_Click"/>
        </StackPanel>

        <!-- Статус-бар -->
        <Border Grid.Row="1" Background="#FF15151B" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Timer Resolution" Foreground="#FF858E9E" FontSize="11"/>
                    <TextBlock x:Name="TimerText" Text="—" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock x:Name="AdminText" Grid.Column="1" Text="" Foreground="#FF858E9E"
                           VerticalAlignment="Bottom" Margin="14,0,0,2"/>
                <CheckBox x:Name="HoldTimerCheck" Grid.Column="2" VerticalAlignment="Center"
                          Content="Держать 0.5 ms" Foreground="#FFE3E6EB"
                          Checked="HoldTimer_Checked" Unchecked="HoldTimer_Unchecked"/>
            </Grid>
        </Border>

        <!-- Боковая панель + контент -->
        <TabControl x:Name="Nav" Grid.Row="2" TabStripPlacement="Left" Background="Transparent"
                    SelectionChanged="Nav_SelectionChanged">

            <!-- БАЗОВОЕ -->
            <TabItem Header="Базовое" Tag="&#xE945;">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Универсально и безопасно на любом ПК"
                                   FontWeight="SemiBold" Foreground="#FF55B585" Margin="2,0,0,8"/>
                        <ItemsControl x:Name="TweaksItems" ItemTemplate="{StaticResource TweakTemplate}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ИГРОВЫЕ -->
            <TabItem Header="Игровые" Tag="&#xE7FC;">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Опциональные оптимизации (по умолчанию выкл)"
                                   FontWeight="SemiBold" Foreground="#FFC9952E" Margin="2,0,0,8"/>
                        <ItemsControl x:Name="GameTweaksItems" ItemTemplate="{StaticResource TweakTemplate}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- СЕТЬ -->
            <TabItem Header="Сеть" Tag="&#xE774;">
                <TabControl TabStripPlacement="Top" Background="Transparent" Margin="0,2,0,0">
                    <TabControl.Resources>
                        <!-- Верхние под-вкладки (пилюли), переопределяют рельсу -->
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="#FF858E9E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="b" Background="#FF15151B" CornerRadius="8" Padding="16,8" Margin="0,0,8,12">
                                            <ContentPresenter ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#FF1E1E26"/></Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#FF1F9E58"/>
                                                <Setter Property="Foreground" Value="#FFEDEFF2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- ===== Состояние сети ===== -->
                    <TabItem Header="Состояние сети">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Состояние соединения -->
                                <Border Background="#FF15151B" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Состояние соединения" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                                            <Button x:Name="MonitorButton" Content="Включить мониторинг" HorizontalAlignment="Right"
                                                    Padding="14,6" Click="MonitorButton_Click"/>
                                        </Grid>
                                        <Border x:Name="MonStatusPill" Background="#FF1E1E26" CornerRadius="6" Padding="12,7"
                                                Margin="0,12,0,0" HorizontalAlignment="Left">
                                            <TextBlock x:Name="MonStatus" Text="выключено" Foreground="#FF858E9E" FontWeight="SemiBold"/>
                                        </Border>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Задержка" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="MonLatency" Text="—" FontSize="24" FontWeight="Bold"/></StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Потеря пакетов" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="MonLoss" Text="—" FontSize="24" FontWeight="Bold"/></StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Скачки пинга" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="MonJitter" Text="—" FontSize="24" FontWeight="Bold"/></StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Пики" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="MonPeaks" Text="—" FontSize="24" FontWeight="Bold"/></StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Тест скорости -->
                                <Border Background="#FF15151B" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Тест скорости интернета" FontWeight="SemiBold" FontSize="15"/>
                                                <TextBlock x:Name="SpeedStatus" Text="многопоточный замер — точнее браузера" Foreground="#FF858E9E" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <ComboBox x:Name="SpeedServerCombo" Width="160" Margin="0,0,8,0">
                                                    <ComboBoxItem Content="Selectel (RU)" Tag="selectel" IsSelected="True"/>
                                                    <ComboBoxItem Content="Cloudflare (глобал)" Tag="cf"/>
                                                </ComboBox>
                                                <Button x:Name="SpeedTestButton" Content="Запустить" Background="#FF1F9E58" Padding="14,6" Click="SpeedTest_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Загрузка" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="SpeedDown" Text="—" FontSize="28" FontWeight="Bold"/></StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Отдача" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="SpeedUp" Text="—" FontSize="28" FontWeight="Bold"/></StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Пинг" Foreground="#FF858E9E" FontSize="11"/>
                                                <TextBlock x:Name="SpeedPing" Text="—" FontSize="28" FontWeight="Bold"/></StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Пинг сети ===== -->
                    <TabItem Header="Пинг сети">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FF15151B" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Тест:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#FF858E9E"/>
                                            <ComboBox x:Name="NetTestCombo" Width="150">
                                                <ComboBoxItem Content="Ping" Tag="ping" IsSelected="True"/>
                                                <ComboBoxItem Content="TCPing" Tag="tcp"/>
                                                <ComboBoxItem Content="Трассировка" Tag="trace"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <Button x:Name="NetStartButton" Content="Начать тест" HorizontalAlignment="Right"
                                                Background="#FF1F9E58" Padding="14,6" Click="NetStart_Click"/>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NetTarget" Grid.Column="0" Text="www.google.com" Padding="8,6"
                                                 Background="#FF0A0A0E" Foreground="#FFE3E6EB" BorderBrush="#FF262630"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="порт:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#FF858E9E"/>
                                            <TextBox x:Name="NetPort" Text="443" Width="64" Padding="8,6"
                                                     Background="#FF0A0A0E" Foreground="#FFE3E6EB" BorderBrush="#FF262630"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Background="#FF15151B" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                <Grid>
                                    <TextBlock Text="Проверка сети на ошибки: шлюз, интернет, DNS, ошибки адаптера."
                                               Foreground="#FF858E9E" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button x:Name="NetScanButton" Content="Сканировать сеть" HorizontalAlignment="Right"
                                            Padding="14,6" Click="NetScan_Click"/>
                                </Grid>
                            </Border>
                            <TextBox x:Name="NetOutput" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                                     Background="#FF050507" Foreground="#FFAEB6C2" BorderBrush="#FF262630" Padding="10"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- DNS -->
            <TabItem Header="DNS" Tag="&#xE72E;">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="DNS-серверы по отклику" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DnsResetButton" Content="Сбросить на DHCP" Padding="12,6" Margin="0,0,8,0" Click="DnsReset_Click"/>
                            <Button x:Name="DnsMeasureButton" Content="Обновить отклики" Background="#FF1F9E58" Padding="12,6" Click="DnsMeasure_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="DnsCurrentText" Grid.Row="1" Foreground="#FF858E9E" Margin="2,0,0,8" Text="Текущий DNS: —"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DnsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF15151B" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Ips}" Foreground="#FF858E9E" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding LatencyText}" Foreground="{Binding Accent}"
                                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <Button Grid.Column="2" Content="Выбрать" Tag="{Binding}" Click="DnsApply_Click"
                                                    Padding="14,6" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Grid.Row="3" Foreground="#FFC9952E" FontSize="11" TextWrapping="Wrap" Margin="2,8,0,0"
                               Text="Внимание: «Выбрать» меняет DNS на активном адаптере. Если DNS управляется роутером/VPN (OpenWrt, podkop) — может конфликтовать. «Сбросить на DHCP» вернёт как было."/>
                </Grid>
            </TabItem>

            <!-- DPC-МЕТР -->
            <TabItem Header="DPC-метр" Tag="&#xE916;">
                <StackPanel>
                    <Border Background="#FF15151B" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Живой замер задержки отклика" FontWeight="SemiBold"
                                           FontSize="15" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="MeterResetButton" Content="Сброс" Padding="12,6" Margin="0,0,8,0" Click="MeterReset_Click"/>
                                    <Button x:Name="MeterButton" Content="Включить" Padding="14,6" Click="MeterButton_Click"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="сейчас" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="MeterCurrent" Text="—" FontSize="40" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="максимум (за 5 сек)" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="MeterMax" Text="—" FontSize="40" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock Foreground="#FF858E9E" FontSize="12" TextWrapping="Wrap" Margin="2,12,0,0"
                               Text="Цвет: зелёный &lt;500, жёлтый &lt;1000, красный &gt;1000 µs. Максимум — за последние 5 сек (старые спайки уходят), «Сброс» обнуляет. ВАЖНО: на простое ПК спайки это норма (ядра CPU уходят в сон) — показателен замер под нагрузкой / в игре."/>
                </StackPanel>
            </TabItem>

            <!-- УСКОРЕНИЕ -->
            <TabItem Header="Ускорение" Tag="&#xE90F;">
                <StackPanel>
                    <Border Background="#FF15151B" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Очистка оперативной памяти" FontWeight="SemiBold"
                                           FontSize="15" VerticalAlignment="Center"/>
                                <Button x:Name="CleanRamButton" Content="Очистить память" HorizontalAlignment="Right"
                                        Background="#FF1F9E58" Padding="14,6" Click="CleanRam_Click"/>
                            </Grid>
                            <TextBlock x:Name="MemText" Text="—" Foreground="#FF858E9E" Margin="0,14,0,0"/>
                            <ProgressBar x:Name="MemBar" Height="12" Margin="0,8,0,0" Minimum="0" Maximum="100"
                                         Foreground="#FF6C9CE0" Background="#FF0A0A0E" BorderThickness="0"/>
                            <TextBlock x:Name="MemResult" Text="" Foreground="#FF55B585" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Foreground="#FF565E6E" FontSize="11" TextWrapping="Wrap" Margin="2,10,0,0"
                               Text="Очистка освобождает рабочие наборы процессов (working set) — временно высвобождает RAM. Безопасно: Windows сам подгрузит нужное обратно."/>
                </StackPanel>
            </TabItem>

            <!-- ДИАГНОСТИКА -->
            <TabItem Header="Диагностика" Tag="&#xE721;">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Сканер находит, что можно оптимизировать именно на этом ПК."
                                   Foreground="#FF858E9E" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button x:Name="ScanButton" Content="Сканировать систему" HorizontalAlignment="Right"
                                Background="#FF1F9E58" Padding="14,7" Click="ScanButton_Click"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FindingsItems" ItemTemplate="{StaticResource FindingTemplate}"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ДРАЙВЕРЫ -->
            <TabItem Header="Драйверы" Tag="&#xE896;">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Драйверы устройств" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DriverWuButton" Content="Проверить Windows Update" Padding="12,6" Margin="0,0,8,0" Click="DriverWu_Click"/>
                            <Button x:Name="DriverScanButton" Content="Сканировать драйверы" Background="#FF1F9E58" Padding="12,6" Click="DriverScan_Click"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DriverItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF15151B" CornerRadius="8" Margin="0,0,0,8">
                                        <Grid>
                                            <Border Width="4" HorizontalAlignment="Left" Background="{Binding Accent}" CornerRadius="8,0,0,8"/>
                                            <Grid Margin="16,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Details}" Foreground="#FF858E9E" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#FF262630" CornerRadius="4" Padding="7,2" Margin="8,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{Binding Accent}"/>
                                                </Border>
                                                <Button Grid.Column="2" Content="{Binding ActionText}" Tag="{Binding ActionUrl}" Click="DriverLink_Click"
                                                        Padding="12,5" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <!-- Обновления из Windows Update (после проверки) -->
                    <Border x:Name="WuPanel" Grid.Row="2" Background="#FF15151B" CornerRadius="8" Padding="14" Margin="0,8,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <Grid>
                                <TextBlock x:Name="WuStatus" Text="Windows Update" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button x:Name="WuInstallAll" Content="Установить все" HorizontalAlignment="Right"
                                        Background="#FF1F9E58" Padding="12,6" Click="WuInstallAll_Click"/>
                            </Grid>
                            <ItemsControl x:Name="WuItems" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Title}" Foreground="#FFAEB6C2"
                                                       TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Button Grid.Column="1" Content="Установить" Tag="{Binding}" Click="WuInstall_Click"
                                                    Padding="10,4" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="3" Foreground="#FF858E9E" FontSize="11" TextWrapping="Wrap" Margin="2,8,0,0"
                               Text="Сторонние драйверы: «Сайт» — офиц. загрузка вендора, «Найти» — поиск в интернете (самый надёжный способ обновления вручную). «Проверить Windows Update» найдёт и поставит проверенные драйверы из каталога Microsoft. Системные драйверы Microsoft в списке не показываем — они обновляются вместе с Windows."/>
                </Grid>
            </TabItem>

            <!-- О СИСТЕМЕ -->
            <TabItem Header="О системе" Tag="&#xE946;">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,2,0,0">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Информация о системе" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            <Button x:Name="SysInfoButton" Content="Обновить" HorizontalAlignment="Right" Padding="12,6" Click="SysInfo_Click"/>
                        </Grid>

                        <UniformGrid Columns="2">
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Система" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysBoard" Text="—" FontWeight="SemiBold" Margin="0,3,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Процессор" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysCpu" Text="—" FontWeight="SemiBold" Margin="0,3,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Видеокарта" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysGpu" Text="—" FontWeight="SemiBold" Margin="0,3,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Память" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysRam" Text="—" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Накопитель" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysStorage" Text="—" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Windows" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysWin" Text="—" FontWeight="SemiBold" Margin="0,3,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Время работы" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysUptime" Text="—" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,12" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Оценка ПК (WEI)" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="SysWei" Text="—" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel></Border>
                        </UniformGrid>

                        <TextBlock Text="Нагрузка в реальном времени" FontWeight="SemiBold" Foreground="#FF55B585" Margin="2,6,0,8"/>
                        <UniformGrid Columns="4">
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,14" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Процессор" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="TileCpu" Text="—" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,14" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Память" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="TileMem" Text="—" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,14" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Процессы" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="TileProc" Text="—" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel></Border>
                            <Border Background="#FF15151B" CornerRadius="10" Padding="16,14" Margin="0,0,10,10">
                                <StackPanel><TextBlock Text="Сеть (всего)" Foreground="#FF858E9E" FontSize="12"/>
                                    <TextBlock x:Name="TileNet" Text="—" FontSize="26" FontWeight="Bold" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="TileNetSpeed" Text="" Foreground="#FF858E9E" FontSize="11" Margin="0,2,0,0"/></StackPanel></Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- НАСТРОЙКИ -->
            <TabItem Header="Настройки" Tag="&#xE713;">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Поведение приложения" FontWeight="SemiBold" Foreground="#FF55B585" Margin="2,0,0,8"/>
                        <Border Background="#FF15151B" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                            <StackPanel>
                                <CheckBox x:Name="AutoStartCheck" Content="Запуск при старте Windows"
                                          Foreground="#FFE3E6EB" Checked="AutoStart_Checked" Unchecked="AutoStart_Unchecked"/>
                                <TextBlock Foreground="#FF858E9E" FontSize="11" TextWrapping="Wrap" Margin="22,4,0,12"
                                           Text="Чтобы держать таймер 0.5 ms всегда, программа должна быть запущена. С автозапуском это происходит само."/>
                                <CheckBox x:Name="MinTrayCheck" Content="Сворачивать в трей при закрытии"
                                          Foreground="#FFE3E6EB" Checked="MinTray_Checked" Unchecked="MinTray_Unchecked"/>
                                <TextBlock Foreground="#FF858E9E" FontSize="11" TextWrapping="Wrap" Margin="22,4,0,0"
                                           Text="Крестик сворачивает в трей (значок у часов) — программа продолжает держать 0.5 ms в фоне. Выход — через меню трея."/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Размер окна" FontWeight="SemiBold" Foreground="#FF55B585" Margin="2,8,0,8"/>
                        <Border Background="#FF15151B" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                            <Grid>
                                <TextBlock Text="Выбери удобный размер окна" Foreground="#FF858E9E" VerticalAlignment="Center"/>
                                <ComboBox x:Name="WindowSizeCombo" HorizontalAlignment="Right" Width="220"
                                          SelectionChanged="WindowSizeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Компактный (860 × 680)" Tag="860,680"/>
                                    <ComboBoxItem Content="Средний (940 × 760)" Tag="940,760" IsSelected="True"/>
                                    <ComboBoxItem Content="Большой (1160 × 900)" Tag="1160,900"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <TextBlock Text="О программе" FontWeight="SemiBold" Foreground="#FF55B585" Margin="2,8,0,8"/>
                        <Border Background="#FF15151B" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="AntiLag" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="v0.4.3" Foreground="#FF858E9E" FontSize="12" VerticalAlignment="Bottom" Margin="6,0,0,2"/>
                                </StackPanel>
                                <TextBlock Foreground="#FF858E9E" TextWrapping="Wrap"
                                           Text="Снижает задержки и держит таймер 0.5 ms. Лечит причину, диагностирует железо и сеть, откатывает изменения в один клик. Работает строго в user-mode (безопасно для анти-читов)."/>
                                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap">
                                    <Run Text="Автор: " Foreground="#FF858E9E"/><Run Text="AxelNerv" Foreground="#FF55B585" FontWeight="SemiBold"/>
                                    <LineBreak/>
                                    <Run Text="Создано с Claude Code" Foreground="#FF858E9E"/>
                                </TextBlock>
                                <TextBlock x:Name="BackupPathText" Foreground="#FF565E6E" FontSize="11" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Глобальная панель действий -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <Border x:Name="RebootBox" Background="#FF2A220E" CornerRadius="8" Padding="12,8" Margin="0,0,0,8" Visibility="Collapsed">
                <TextBlock Foreground="#FFD9A53A" TextWrapping="Wrap"
                           Text="Нужна перезагрузка, чтобы флаг таймера заработал на всю систему."/>
            </Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="ApplyButton" Content="Применить выбранное"
                        Background="#FF1F9E58" Click="ApplyButton_Click"/>
                <Button Grid.Column="2" x:Name="UndoButton" Content="Откатить всё" Click="UndoButton_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
